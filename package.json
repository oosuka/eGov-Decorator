{
  "name": "egov-decorator",
  "version": "1.2.3",
  "private": true,
  "scripts": {
    "check": "biome check . --error-on-warnings",
    "lint": "biome lint . --error-on-warnings",
    "test": "node --test",
    "coverage": "node --test --experimental-test-coverage",
    "fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "husky": "^9.1.7"
  },
  "volta": {
    "node": "24.14.0",
    "npm": "11.9.0"
  }
}
